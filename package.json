{
  "name": "rush-shimo-cli",
  "version": "0.1.0",
  "description": "石墨文档 CLI + SDK + MCP — read Shimo documents from terminal and AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shimo": "./dist/index.js",
    "rush-shimo": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kanyun-inc/rush-shimo-cli"
  },
  "license": "MIT",
  "keywords": [
    "shimo",
    "石墨",
    "cli",
    "mcp",
    "sdk"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
